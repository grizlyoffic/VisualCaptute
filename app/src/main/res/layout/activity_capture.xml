<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#1a1a2e">
    
    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="15dp"
        android:background="#16213e">
        
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="HTTP Capture"
            android:textSize="18sp"
            android:textColor="#fff"
            android:textStyle="bold"/>
        
        <TextView
            android:id="@+id/tvServerStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🔴 Server Stopped"
            android:textSize="12sp"
            android:textColor="#ff6b6b"/>
            
    </LinearLayout>
    
    <!-- Start/Stop Button -->
    <Button
        android:id="@+id/btnStart"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:text="▶ START CAPTURE"
        android:backgroundTint="#e94560"
        android:textColor="#fff"
        android:layout_margin="15dp"/>
    
    <!-- Logs -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="150dp"
        android:background="#0f3460"
        android:padding="10dp"
        android:layout_margin="10dp">
        
        <TextView
            android:id="@+id/tvLogs"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Waiting to start capture...\n"
            android:textColor="#00ff00"
            android:textSize="12sp"
            android:typeface="monospace"/>
            
    </ScrollView>
    
    <!-- Requests List -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="📥 Captured Requests"
        android:textSize="16sp"
        android:textColor="#fff"
        android:textStyle="bold"
        android:padding="10dp"/>
    
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#16213e"
        android:padding="5dp"/>
    
</LinearLayout>